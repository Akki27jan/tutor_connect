# Database — SQLite for local dev, PostgreSQL for production
DATABASE_URL=sqlite+aiosqlite:///./tutoring.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/tutoring

# JWT
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Google Calendar (optional — booking works without it)
GOOGLE_CREDENTIALS_FILE=
GOOGLE_CALENDAR_ID=

# CORS
FRONTEND_URL=http://localhost:3000
